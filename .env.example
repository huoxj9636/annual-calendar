# ===========================================
# 年度计划日历 - 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填入你的配置：
#   cp .env.example .env.local
# ===========================================

# ----- LLM API 配置（AI 功能所需） -----
# 如果你在本地运行，需要配置以下变量来启用 AI 功能（日程拆解、每日洞察、轨迹分析）
# 如果不配置，AI 功能将不可用，但日历核心功能不受影响

# API Key（必填，启用 AI 功能）
LLM_API_KEY=

# API Base URL（可选，默认为火山引擎豆包 API）
# 支持任何 OpenAI 兼容的 API，例如：
#   火山引擎豆包: https://ark.cn-beijing.volces.com/api/v3
#   OpenAI:       https://api.openai.com/v1
#   DeepSeek:     https://api.deepseek.com/v1
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型名称（可选，默认为 doubao-seed-2-0-mini-260215）
# 根据你的 API 提供商选择合适的模型，例如：
#   豆包:   doubao-seed-2-0-mini-260215
#   OpenAI: gpt-4o-mini
#   DeepSeek: deepseek-chat
LLM_MODEL=doubao-seed-2-0-mini-260215

# ----- 服务端口（可选） -----
# PORT=5000
